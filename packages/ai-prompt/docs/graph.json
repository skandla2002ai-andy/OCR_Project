{
  "meta": {
    "title": "AI Prompt PWA — Architecture Diagram Graph",
    "description": "Nodes + edges derived from ontology.json. Compatible with Cytoscape.js, D3.js force-layout, and Mermaid. Layers are colour-coded; edge labels map to ontology objectProperties.",
    "version": "1.0.0",
    "ontologyRef": "./ontology.json",
    "renderers": {
      "cytoscape": "Pass elements[] directly to cytoscape({ container, elements, style, layout })",
      "d3": "Use nodes[] and edges[] arrays; id/source/target fields match D3 force-link conventions",
      "mermaid": "Copy mermaidSource string to https://mermaid.live or embed in Markdown ```mermaid block"
    }
  },

  "layers": [
    { "id": "Infrastructure", "color": "#94a3b8", "shape": "diamond" },
    { "id": "Presentation", "color": "#6366f1", "shape": "roundrectangle" },
    { "id": "Logic", "color": "#8b5cf6", "shape": "hexagon" },
    { "id": "Service", "color": "#06b6d4", "shape": "rectangle" },
    { "id": "Domain", "color": "#f59e0b", "shape": "ellipse" },
    { "id": "External", "color": "#475569", "shape": "cut-rectangle" }
  ],

  "edgeTypes": [
    { "id": "renders", "color": "#6366f1", "style": "solid", "label": "renders" },
    { "id": "usesHook", "color": "#8b5cf6", "style": "dashed", "label": "usesHook" },
    { "id": "callsService", "color": "#06b6d4", "style": "solid", "label": "callsService" },
    { "id": "persistsUsing", "color": "#22c55e", "style": "solid", "label": "persistsUsing" },
    { "id": "streamsWith", "color": "#f59e0b", "style": "dashed", "label": "streamsWith" },
    { "id": "dependsOnLib", "color": "#94a3b8", "style": "dotted", "label": "dependsOn" },
    { "id": "usesAPI", "color": "#ec4899", "style": "dashed", "label": "usesAPI" },
    { "id": "registers", "color": "#f97316", "style": "solid", "label": "registers" },
    { "id": "typedWith", "color": "#f59e0b", "style": "dotted", "label": "typedWith" },
    { "id": "injectsContext", "color": "#84cc16", "style": "dashed", "label": "injectsCtx" }
  ],

  "nodes": [
    {
      "id": "main",
      "label": "main.tsx",
      "class": "EntryPoint",
      "layer": "Infrastructure",
      "filePath": "src/main.tsx",
      "desc": "Bootstrap: mounts App, registers Service Worker"
    },

    {
      "id": "App",
      "label": "App.tsx",
      "class": "RootComponent",
      "layer": "Presentation",
      "filePath": "src/App.tsx",
      "desc": "Global state owner & layout orchestrator",
      "state": [
        "activeConvId",
        "settings",
        "pendingFiles",
        "viewerOpen",
        "viewerWidth",
        "streamText",
        "sidebarOpen"
      ]
    },
    {
      "id": "ConversationSidebar",
      "label": "ConversationSidebar",
      "class": "NavigationComponent",
      "layer": "Presentation",
      "filePath": "src/components/ConversationSidebar.tsx",
      "desc": "Conversation list — select / create / delete"
    },
    {
      "id": "MessageList",
      "label": "MessageList",
      "class": "LayoutComponent",
      "layer": "Presentation",
      "filePath": "src/components/MessageList.tsx",
      "desc": "Chat bubbles + streaming cursor"
    },
    {
      "id": "PromptInput",
      "label": "PromptInput",
      "class": "LayoutComponent",
      "layer": "Presentation",
      "filePath": "src/components/PromptInput.tsx",
      "desc": "Controlled input; file chips; drag-drop zone"
    },
    {
      "id": "FilePreview",
      "label": "FilePreview",
      "class": "PrimitiveComponent",
      "layer": "Presentation",
      "filePath": "src/components/FilePreview.tsx",
      "desc": "Compact image/PDF attachment chips"
    },
    {
      "id": "ViewerPanel",
      "label": "ViewerPanel",
      "class": "LayoutComponent",
      "layer": "Presentation",
      "filePath": "src/components/ViewerPanel.tsx",
      "desc": "Resizable file viewer: thumbnails + full preview"
    },
    {
      "id": "SettingsPanel",
      "label": "SettingsPanel",
      "class": "OverlayComponent",
      "layer": "Presentation",
      "filePath": "src/components/SettingsPanel.tsx",
      "desc": "Provider / model / system-prompt settings overlay"
    },

    {
      "id": "useAI",
      "label": "useAI",
      "class": "AIStreamHook",
      "layer": "Logic",
      "filePath": "src/hooks/useAI.ts",
      "desc": "Stream lifecycle: idle → streaming → done|error + abort"
    },
    {
      "id": "useDb",
      "label": "useDb",
      "class": "StorageHook",
      "layer": "Logic",
      "filePath": "src/hooks/useDb.ts",
      "desc": "Reactive DB queries via Dexie useLiveQuery"
    },
    {
      "id": "useClipboard",
      "label": "useClipboard",
      "class": "InputHook",
      "layer": "Logic",
      "filePath": "src/hooks/useClipboard.ts",
      "desc": "Paste-event image capture + navigator.clipboard.read()"
    },
    {
      "id": "useDragDrop",
      "label": "useDragDrop",
      "class": "InputHook",
      "layer": "Logic",
      "filePath": "src/hooks/useDragDrop.ts",
      "desc": "Drag & drop with isDragging overlay flag"
    },

    {
      "id": "aiService",
      "label": "ai.ts",
      "class": "AIService",
      "layer": "Service",
      "filePath": "src/services/ai.ts",
      "desc": "4-provider streaming engine (Anthropic|Proxy|Ollama|OpenAI)"
    },
    {
      "id": "dbService",
      "label": "db.ts",
      "class": "PersistenceService",
      "layer": "Service",
      "filePath": "src/services/db.ts",
      "desc": "Dexie CRUD: conversations / messages / settings"
    },
    {
      "id": "pdfService",
      "label": "pdf.ts",
      "class": "MediaService",
      "layer": "Service",
      "filePath": "src/services/pdf.ts",
      "desc": "PDF text extraction + blob URL lifecycle"
    },
    {
      "id": "apiService",
      "label": "api.ts",
      "class": "NetworkService",
      "layer": "Service",
      "filePath": "src/services/api.ts",
      "desc": "Generic HTTP fetch helper"
    },

    {
      "id": "types",
      "label": "types/index.ts",
      "class": "TypeModule",
      "layer": "Domain",
      "filePath": "src/types/index.ts",
      "desc": "Discriminated unions, interfaces, type guards, constants",
      "exports": [
        "ImageAttachment",
        "PdfAttachment",
        "FileAttachment",
        "Message",
        "Conversation",
        "AppSettings",
        "ApiProvider",
        "AIModel",
        "isPdf",
        "isImage",
        "DEFAULT_SETTINGS"
      ]
    },

    {
      "id": "AnthropicAPI",
      "label": "Anthropic Claude API",
      "class": "AIProvider",
      "layer": "External",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "protocol": "SDK-stream",
      "auth": "APIKey"
    },
    {
      "id": "ServerProxy",
      "label": "Server Proxy (SSE)",
      "class": "AIProvider",
      "layer": "External",
      "endpoint": "/api/ai (configurable)",
      "protocol": "SSE",
      "auth": "None (server-side)"
    },
    {
      "id": "OllamaAPI",
      "label": "Ollama (Local LLM)",
      "class": "AIProvider",
      "layer": "External",
      "endpoint": "http://localhost:11434/api/chat",
      "protocol": "NDJSON",
      "auth": "None"
    },
    {
      "id": "OpenAIAPI",
      "label": "OpenAI / Compatible",
      "class": "AIProvider",
      "layer": "External",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "protocol": "SSE",
      "auth": "BearerToken"
    },
    {
      "id": "IndexedDB",
      "label": "IndexedDB (Dexie v4)",
      "class": "StorageEngine",
      "layer": "External",
      "desc": "3 object stores: conversations, messages, settings"
    },
    {
      "id": "pdfjsDist",
      "label": "pdfjs-dist",
      "class": "Library",
      "layer": "External",
      "desc": "Client-side PDF parsing and text extraction"
    },
    {
      "id": "anthropicSDK",
      "label": "@anthropic-ai/sdk",
      "class": "Library",
      "layer": "External",
      "desc": "Official Anthropic TypeScript SDK"
    },
    {
      "id": "dexieLib",
      "label": "Dexie + dexie-react-hooks",
      "class": "Library",
      "layer": "External",
      "desc": "IndexedDB wrapper with useLiveQuery"
    },
    {
      "id": "ClipboardAPI",
      "label": "Clipboard API",
      "class": "BrowserAPI",
      "layer": "External",
      "desc": "navigator.clipboard + ClipboardEvent"
    },
    {
      "id": "DragDropAPI",
      "label": "Drag & Drop API",
      "class": "BrowserAPI",
      "layer": "External",
      "desc": "HTML DnD events + DataTransfer"
    },
    {
      "id": "ServiceWorkerAPI",
      "label": "Service Worker (PWA)",
      "class": "BrowserAPI",
      "layer": "External",
      "desc": "Workbox offline cache via vite-plugin-pwa"
    }
  ],

