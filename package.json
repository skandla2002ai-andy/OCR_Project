{
  "name": "ocr-web-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OCR Web Monorepo with Node 22 + React 18 + Turborepo + TDD",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "start": "pnpm run dev:web",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx --ignore-path .eslintignore",
    "lint:fix": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx --ignore-path .eslintignore --fix",
    "test:core": "pnpm --filter @core-nexus/ocr-core test",
    "test:web": "pnpm --filter web test",
    "dev:web": "pnpm --filter web dev",
    "dev:full": "pnpm run build:core && pnpm run dev:web",
    "build:core": "pnpm --filter @core-nexus/ocr-core build",
    "build:web": "pnpm --filter web build",
    "preview:web": "pnpm --filter web preview",
    "dev:ai": "pnpm --filter @core-nexus/ai-prompt dev",
    "build:ai": "pnpm --filter @core-nexus/ai-prompt build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean",
    "verify:setup": "node scripts/verify-setup.js",
    "test:turborepo": "node scripts/test-turborepo-setup.js",
    "test:node-ts": "node scripts/test-node-ts-setup.js",
    "test:lint": "node scripts/test-lint-setup.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0",
    "@types/node": "^22.7.4"
  }
}
